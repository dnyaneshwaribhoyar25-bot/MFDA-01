import numpy as np

sample_space = np.arange(1, 7)
greater_than_4 = np.array([5, 6])

roll = int(input("Enter a die roll (1-6): "))

if roll in sample_space:
    probability = len(greater_than_4) / len(sample_space)
    if roll in greater_than_4:
        print(f"{roll} is greater than 4.")
    else:
        print(f"{roll} is not greater than 4.")
    print("Probability of getting a number greater than 4:", probability)
else:
    print("Invalid input! Please enter a number from 1 to 6.")
